NODE_ENV=development
PORT=4000
# Local PostgreSQL database managed through pgAdmin 4.
DATABASE_URL="postgresql://postgres:Sadakael%2327@127.0.0.1:5432/EMWA"
# auto enables SSL for remote database hosts and disables it for localhost.
DATABASE_SSL=auto
JWT_ACCESS_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=replace-with-a-different-random-secret-at-least-32-characters-long
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
CORS_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:4000,http://127.0.0.1:5173,http://127.0.0.1:8080
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
TRUST_PROXY=false
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=EMWA
DB_USERNAME=postgres
DB_PASSWORD=Sadakael#27
